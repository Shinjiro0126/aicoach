# Cloudflare Workers プロキシ (proxy/README.md 参照)。未設定の場合はモックAIで動作する
EXPO_PUBLIC_COACH_API_URL=
EXPO_PUBLIC_COACH_APP_TOKEN=

# Sentry (クラッシュ検知)。未設定の場合は無効化される (src/lib/observability/sentry.ts)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog (行動分析)。API キー未設定の場合は no-op になる (src/lib/analytics/posthog.ts)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
